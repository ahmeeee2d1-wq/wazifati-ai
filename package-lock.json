    "node_modules/@rollup/rollup-darwin-cŹx×‹h‘éě¶»§q«^v var(--success-soft); text-align: center; font-size: 11px; font-weight: 700; }
.upload-zone { padding: 38px 22px; border: 1.5px dashed #bccbc6; border-radius: 18px; background: #f9fbfa; text-align: center; transition: .2s ease; }
.upload-zone.drag { border-color: var(--gold); background: var(--gold-soft); }
.upload-icon { width: 58px; height: 58px; margin: 0 auto 14px; display: grid; place-items: center; border-radius: 18px; color: var(--ink); background: var(--ink-soft); }
.upload-zone h3 { margin: 0 0 8px; }
.upload-zone p { margin: 0 0 17px; color: var(--muted); font-size: 11px; }
.resume-file { padding: 14px; display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 14px; background: #fff; }
.file-icon { width: 43px; height: 47px; display: grid; place-items: center; border-radius: 10px; color: var(--danger); background: var(--danger-soft); font-weight: 800; font-size: 10px; }
.resume-file strong { display: block; margin-bottom: 5px; font-size: 12px; }
.resume-file span { color: var(--muted); font-size: 10px; }
.resume-file .spacer { flex: 1; }
.profile-fields { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
.field { display: flex; flex-direction: column; gap: 7px; }
.field.full { grid-column: 1 / -1; }
.field label { color: #4e5c58; font-size: 11px; font-weight: 700; }
.field input, .field textarea, .field select { width: 100%; padding: 12px; border: 1px solid var(--line); border-radius: 11px; outline: 0; background: #faf9f6; transition: .15s ease; }
.field textarea { min-height: 90px; resize: vertical; }
.field input:focus, .field textarea:focus, .field select:focus { border-color: #7fa399; box-shadow: 0 0 0 3px #edf4f1; }
.tags-editor { min-height: 45px; padding: 7px; display: flex; align-items: center; flex-wrap: wrap; gap: 6px; border: 1px solid var(--line); border-radius: 11px; background: #faf9f6; }
.tag { padding: 6px 9px; display: inline-flex; align-items: center; gap: 5px; border-radius: 8px; color: var(--ink); background: var(--ink-soft); font-size: 10px; }
.tag button { padding: 0; border: 0; color: inherit; background: transparent; }
.tag-input { min-width: 120px; flex: 1; border: 0 !important; padding: 5px !important; background: transparent !important; box-shadow: none !important; }
.score-hero { padding: 22px; display: flex; align-items: center; gap: 22px; border-radius: 18px; color: #fff; background: var(--ink); }
.score-hero .ring { width: 104px; height: 104px; background: conic-gradient(var(--gold) calc(var(--value) * 1%), rgba(255,255,255,.15) 0); }
.score-hero .ring::after { background: var(--ink); }
.score-hero .ring strong { color: #fff; }
.score-copy h3 { margin: 0 0 7px; font-size: 19px; }
.score-copy p { margin: 0; color: #b8cbc5; line-height: 1.8; font-size: 11px; }
.score-compare { display: flex; align-items: center; gap: 11px; margin-top: 13px; }
.score-compare span { padding: 6px 9px; border-radius: 8px; background: rgba(255,255,255,.1); font-size: 10px; }
.improvement-list { display: flex; flex-direction: column; gap: 11px; }
.improvement { padding: 12px; display: flex; align-items: start; gap: 10px; border: 1px solid var(--line); border-radius: 12px; font-size: 11px; line-height: 1.7; }
.check { width: 20px; height: 20px; display: grid; place-items: center; flex: 0 0 auto; border-radius: 50%; color: var(--success); background: var(--success-soft); font-weight: 800; }
.cv-preview { padding: 28px; border: 1px solid var(--line); border-radius: 5px; background: #fff; box-shadow: 0 10px 35px rgba(0,0,0,.06); }
.cv-preview h2 { margin: 0 0 5px; color: var(--ink); font-size: 24px; }
.cv-preview .cv-headline { color: var(--gold); font-weight: 700; }
.cv-preview h4 { margin: 22px 0 9px; padding-bottom: 6px; border-bottom: 2px solid var(--ink); color: var(--ink); }
.cv-preview p, .cv-preview li { color: #45524f; font-size: 11px; line-height: 1.9; }
.table-wrap { overflow: auto; }
.data-table { width: 100%; min-width: 800px; border-collapse: collapse; }
.data-table th { padding: 12px 15px; color: var(--muted); background: #faf9f6; font-size: 10px; text-align: right; white-space: nowrap; }
.data-table td { padding: 15px; border-bottom: 1px solid #eeece6; font-size: 11px; vertical-align: middle; }
.data-table tr:last-child td { border-bottom: 0; }
.table-title { display: flex; align-items: center; gap: 10px; }
.table-title .company-logo { width: 37px; height: 37px; border-radius: 10px; font-size: 11px; }
.table-title strong { display: block; margin-bottom: 4px; font-size: 11px; }
.table-title span { color: var(--muted); font-size: 9px; }
.status { padding: 6px 9px; display: inline-flex; align-items: center; gap: 5px; border-radius: 8px; font-size: 9px; font-weight: 700; white-space: nowrap; }
.status::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.status-pending { color: #89611f; background: var(--gold-soft); }
.status-applied { color: var(--info); background: #e9f1f8; }
.status-viewed { color: #68549a; background: #f0ecfa; }
.status-rejected { color: var(--danger); background: var(--danger-soft); }
.status-interview, .status-offer { color: var(--success); background: var(--success-soft); }
.status-select { padding: 7px; border: 1px solid var(--line); border-radius: 8px; outline: 0; background: #fff; font-size: 10px; }
.inbox-layout { display: grid; grid-template-columns: 290px 1fr; min-height: 570px; overflow: hidden; }
.message-list { border-left: 1px solid var(--line); }
.message-item { width: 100%; padding: 17px; display: block; border: 0; border-bottom: 1px solid var(--line); background: #fff; text-align: right; }
.message-item.active { background: #f0f6f3; box-shadow: inset -3px 0 var(--ink); }
.message-item.unread h4::before { content: ""; width: 7px; height: 7px; display: inline-block; margin-left: 6px; border-radius: 50%; background: var(--gold); }
.message-item h4 { margin: 0 0 6px; font-size: 11px; }
.message-item p { margin: 0 0 8px; color: var(--muted); font-size: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.message-item time { color: #9aa39f; font-size: 9px; }
.message-view { padding: 27px; }
.message-view-head { padding-bottom: 20px; border-bottom: 1px solid var(--line); }
.message-view-head h2 { margin: 8px 0; font-size: 20px; }
.message-view-head p { margin: 0; color: var(--muted); }
.message-body { padding: 25px 0; color: #4d5a56; line-height: 2; }
.email-insight { padding: 15px; border-radius: 13px; color: var(--ink); background: var(--success-soft); }
.email-insight strong { display: block; margin-bottom: 7px; }
.email-insight p { margin: 0; font-size: 11px; }
.settings-group { margin-bottom: 18px; }
.setting-row { padding: 17px 0; display: flex; align-items: center; justify-content: space-between; gap: 16px; border-bottom: 1px solid var(--line); }
.setting-row:last-child { border-bottom: 0; }
.setting-copy h4 { margin: 0 0 5px; font-size: 12px; }
.setting-copy p { margin: 0; color: var(--muted); font-size: 10px; line-height: 1.65; }
.toggle { width: 43px; height: 24px; padding: 3px; border: 0; border-radius: 30px; background: #c7cdc9; transition: .2s; }
.toggle::after { content: ""; width: 18px; height: 18px; display: block; border-radius: 50%; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,.15); transition: .2s; }
.toggle.on { background: var(--ink); }
.toggle.on::after { transform: translateX(-19px); }
.automation-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 11px; }
.automation-option { padding: 16px; position: relative; border: 1px solid var(--line); border-radius: 14px; background: #fff; }
.automation-option.selected { border-color: var(--ink); box-shadow: 0 0 0 2px var(--ink-soft); }
.automation-option input { position: absolute; opacity: 0; }
.automation-option strong { display: block; margin-bottom: 7px; color: var(--ink); font-size: 12px; }
.automation-option p { margin: 0; color: var(--muted); font-size: 10px; line-height: 1.7; }
.automation-option .radio { width: 16px; height: 16px; position: absolute; left: 13px; top: 13px; border: 1px solid #aeb9b5; border-radius: 50%; }
.automation-option.selected .radio { border: 5px solid var(--ink); }
.notice { padding: 13px 15px; display: flex; gap: 10px; border-radius: 13px; color: #76531c; background: var(--gold-soft); line-height: 1.7; font-size: 10px; }
.modal-backdrop { position: fixed; inset: 0; z-index: 100; display: grid; place-items: center; padding: 18px; background: rgba(13,32,27,.55); backdrop-filter: blur(4px); }
.modal { width: min(580px, 100%); max-height: calc(100vh - 36px); overflow: auto; border-radius: 22px; background: #fff; box-shadow: 0 25px 80px rgba(0,0,0,.25); }
.modal-head { padding: 19px 22px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--line); }
.modal-head h3 { margin: 0; }
.modal-body { padding: 22px; }
.modal-foot { padding: 16px 22px; display: flex; justify-content: flex-end; gap: 8px; border-top: 1px solid var(--line); }
.apply-summary { padding: 15px; display: flex; gap: 12px; border-radius: 14px; background: #f6f7f4; }
.apply-summary h4 { margin: 2px 0 5px; }
.apply-summary p { margin: 0; color: var(--muted); font-size: 10px; }
.cover-letter { width: 100%; min-height: 150px; margin: 15px 0; padding: 13px; border: 1px solid var(--line); border-radius: 12px; line-height: 1.8; resize: vertical; }
.confirm-line { display: flex; align-items: start; gap: 9px; color: #52605c; font-size: 10px; line-height: 1.7; }
.empty { padding: 45px 20px; color: var(--muted); text-align: center; }
.empty .empty-icon { width: 58px; height: 58px; margin: 0 auto 12px; display: grid; place-items: center; border-radius: 18px; color: var(--ink); background: var(--ink-soft); }
.toast-root { position: fixed; z-index: 200; left: 22px; bottom: 22px; display: flex; flex-direction: column; gap: 8px; }
.toast { min-width: 270px; padding: 13px 16px; display: flex; align-items: center; gap: 9px; border-radius: 12px; color: #fff; background: var(--ink); box-shadow: 0 15px 35px rgba(0,0,0,.2); animation: toast-in .25s ease; }
.toast.error { background: var(--danger); }
@keyframes toast-in { from { opacity: 0; transform: translateY(10px); } }
.login-screen { min-height: 100vh; display: grid; grid-template-columns: 1.1fr .9fr; background: #fff; }
.login-visual { min-height: 100vh; padding: 55px; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; color: #fff; background: var(--ink); }
.login-visual::before, .login-visual::after { content: ""; position: absolute; border: 1px solid rgba(255,255,255,.08); border-radius: 50%; }
.login-visual::before { width: 600px; height: 600px; left: -270px; top: -220px; }
.login-visual::after { width: 450px; height: 450px; right: -270px; bottom: -180px; }
.login-brand { display: flex; align-items: center; gap: 12px; position: relative; z-index: 1; }
.login-brand img { width: 47px; height: 47px; }
.login-brand strong { font-size: 20px; }
.login-message { max-width: 620px; position: relative; z-index: 1; }
.login-message .eyebrow { display: inline-flex; padding: 7px 10px; border-radius: 30px; color: #f3d59b; background: rgba(255,255,255,.08); font-size: 10px; }
.login-message h1 { margin: 19px 0; font-size: clamp(34px, 5vw, 58px); line-height: 1.25; letter-spacing: -2px; }
.login-message h1 span { color: var(--gold); }
.login-message > p { max-width: 520px; margin: 0; color: #bed0ca; line-height: 2; font-size: 14px; }
.feature-row { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 10px; }
.feature-chip { padding: 9px 12px; display: flex; align-items: center; gap: 7px; border: 1px solid rgba(255,255,255,.1); border-radius: 10px; background: rgba(255,255,255,.05); font-size: 11px; }
.login-caption { position: relative; z-index: 1; color: #78978d; font-size: 10px; }
.login-panel { padding: 40px; display: grid; place-items: center; background: #fbfaf7; }
.login-card { width: min(420px, 100%); }
.login-card h2 { margin: 0 0 8px; font-size: 27px; }
.login-card > p { margin: 0 0 28px; color: var(--muted); line-height: 1.8; }
.login-card .field { margin-bottom: 13px; }
.login-card .btn { width: 100%; margin-top: 6px; }
.demo-note { margin-top: 18px; padding: 12px; border-radius: 12px; color: #66522e; background: var(--gold-soft); font-size: 10px; line-height: 1.7; text-align: center; }
.cloud-note { color: var(--ink); background: var(--success-soft); }
.cloud-badge { width: fit-content; margin-bottom: 13px; padding: 6px 9px; display: inline-flex; border-radius: 20px; color: var(--success); background: var(--success-soft); font-size: 10px; font-weight: 700; }
.cloud-badge.top-cloud { margin: 0 0 0 4px; white-space: nowrap; }
.legal-links { margin-top: 15px; display: flex; justify-content: center; gap: 8px; color: var(--muted); font-size: 10px; }
.legal-links a:hover { color: var(--ink); text-decoration: underline; }
.mobile-nav { display: none; }
.loading { display: inline-flex; align-items: center; gap: 8px; }
.loading::before { content: ""; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4); border-top-color: #fff; border-radius: 50%; animation: spin .7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

@media (max-width: 1100px) {
  .stats { grid-template-columns: repeat(2, 1fr); }
  .grid-2 { grid-template-columns: 1fr; }
  .job-grid { grid-template-columns: 1fr; }
}
@media (max-width: 820px) {
  .app-shell { display: block; }
  .sidebar { display: none; }
  .main { width: 100%; }
  .topbar { height: 68px; padding: 0 18px; }
  .content { padding: 22px 16px 90px; }
  .mobile-nav { height: 67px; display: grid; grid-template-columns: repeat(5, 1fr); position: fixed; inset: auto 0 0; z-index: 60; border-top: 1px solid var(--line); background: rgba(255,255,255,.96); backdrop-filter: blur(14px); }
  .mobile-nav button { padding: 7px 2px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; border: 0; color: var(--muted); background: transparent; font-size: 8px; }
  .mobile-nav button.active { color: var(--ink); }
  .mobile-nav .icon { width: 19px; height: 19px; }
  .login-screen { grid-template-columns: 1fr; }
  .login-visual { min-height: 45vh; padding: 32px 24px; }
  .login-message h1 { font-size: 35px; }
  .login-caption { display: none; }
  .login-panel { padding: 35px 20px; }
  .inbox-layout { grid-template-columns: 1fr; }
  .message-list { border-left: 0; }
  .message-view { display: none; }
}
@media (max-width: 580px) {
  .welcome { align-items: stretch; flex-direction: column; }
  .stats, .grid-equal, .profile-fields, .automation-options { grid-template-columns: 1fr; }
  .section-tools { align-items: stretch; flex-direction: column; }
  .section-tools > * { width: 100%; }
  .score-hero { align-items: start; flex-direction: column; }
  .topbar .page-kicker { display: none; }
  .topbar h1 { font-size: 18px; }
  .top-cloud { display: none; }
}
